{
  "name": "witnessed-extension",
  "version": "0.4.0",
  "description": "Auto-BCC seal@witnessed.cc on Gmail composes, and look up every visible sender's Witnessed proof-of-business record at a click.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "zip": "cd dist && zip -r ../witnessed-extension.zip . -x '.vite/*' '.vite'"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
