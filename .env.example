# Vercel Postgres — set automatically when you add a Postgres store in the Vercel dashboard.
# For local dev, copy from your Vercel project settings → Storage → your DB → .env.local
DATABASE_URL=

# Secret shared with the Cloudflare Worker to authenticate inbound webhook calls.
# Generate with: openssl rand -hex 32
INBOUND_SECRET=

# Optional: enables the internal /ops/<token> dashboard. Must be at least
# 16 characters. Rotate to revoke the URL. Generate with: openssl rand -hex 32
STATS_TOKEN=

# Optional: Spamhaus DQS key for the DBL (domain block list) lookup.
# Free tier up to 100k queries/day — register at
# https://www.spamhaus.com/free-trial/. When unset, the DBL layer is
# skipped entirely (the public dbl.spamhaus.org zone refuses queries
# from serverless runtimes, so the lookup would be pure overhead).
SPAMHAUS_DQS_KEY=

# Optional: HMAC key for the /api/rights/* DNS-TXT challenges. Falls
# back to INBOUND_SECRET when unset (the default — there's no reason
# to split them unless you want to rotate rights challenges without
# rotating the inbound webhook secret). Rotating this invalidates
# every challenge minted before the rotation.
RIGHTS_SECRET=
