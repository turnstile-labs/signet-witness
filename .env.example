# Vercel Postgres — set automatically when you add a Postgres store in the Vercel dashboard.
# For local dev, copy from your Vercel project settings → Storage → your DB → .env.local
DATABASE_URL=

# Secret shared with the Cloudflare Worker to authenticate inbound webhook calls.
# Generate with: openssl rand -hex 32
INBOUND_SECRET=

# Optional: enables the internal /ops/<token> dashboard. Must be at least
# 16 characters. Rotate to revoke the URL. Generate with: openssl rand -hex 32
STATS_TOKEN=
